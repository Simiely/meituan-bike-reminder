<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <!-- Center section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/centerContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Bike icon -->
        <TextView
            android:id="@+id/bikeIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚲"
            android:textSize="72sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="一键开始骑车"
            android:textSize="22sp"
            android:textColor="@color/primary_dark"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/bikeIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Description -->
        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击后自动执行："
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Action list -->
        <TextView
            android:id="@+id/action1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱  创建 50 分钟倒计时"
            android:textSize="16sp"
            android:textColor="@color/on_surface"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/action2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📸  打开美团扫一扫"
            android:textSize="16sp"
            android:textColor="@color/on_surface"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/action1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BIG BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartRiding"
            android:layout_width="280dp"
            android:layout_height="64dp"
            android:text="@string/start_riding"
            android:textSize="22sp"
            android:textColor="@color/on_primary"
            app:cornerRadius="32dp"
            app:backgroundTint="@color/primary"
            app:icon="@android:drawable/ic_media_play"
            app:iconGravity="textStart"
            app:iconSize="28dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/action2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ====== 设置区域（默认隐藏） ====== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/settingsPanel"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:background="@drawable/settings_bg"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnStartRiding"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/settingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱ 倒计时时长（分钟）"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <NumberPicker
                android:id="@+id/minutePicker"
                android:layout_width="wrap_content"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/settingsTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="💾 保存设置"
                android:textSize="16sp"
                android:textColor="@color/on_primary"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/primary"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/minutePicker"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Status text at bottom -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
